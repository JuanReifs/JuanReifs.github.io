# .htaccess - Apache Configuration
# Compresión, caché, redirecciones y seguridad

# ======== HABILITAR COMPRESIÓN GZIP ========
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE application/font-woff application/font-woff2 font/woff font/woff2
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|svg)$ no-gzip dont-vary
</IfModule>

# ======== CACHÉ DEL NAVEGADOR ========
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Caché de archivos estáticos (1 año)
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # Caché de HTML (1 semana)
    ExpiresByType text/html "access plus 1 week"
    
    # Sin caché para archivos dinámicos
    ExpiresByType application/json "access plus 0 seconds"
    ExpiresByType application/xml "access plus 0 seconds"
</IfModule>

# ======== HEADERS DE SEGURIDAD ========
<IfModule mod_headers.c>
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com;"
    
    # Prevenir clickjacking
    Header set X-Frame-Options "SAMEORIGIN"
    
    # Prevenir MIME sniffing
    Header set X-Content-Type-Options "nosniff"
    
    # Política referrer
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Habilitar XSS protection
    Header set X-XSS-Protection "1; mode=block"
    
    # Feature Policy (Permissions Policy)
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Retirar header de servidor por seguridad
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# ======== REDIRECCIONES 404 ========
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Redirigir 404 a página de error
    ErrorDocument 404 /404.html
    
    # Forzar HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Eliminar www
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]
    
    # Redirigir archivos sin extensión a .html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^\.]+)$ $1.html [L]
    
    # Redirigir índice
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^(.+)$ $1/index.html [L]
</IfModule>

# ======== TIPOS MIME ========
AddType application/json json
AddType application/ld+json jsonld
AddType text/xml xml
AddType application/xml xml
AddType application/rss+xml rss
AddType font/woff2 woff2
AddType font/woff woff
AddType text/plain txt

# ======== DESHABILITAR INDEXADO DE DIRECTORIOS ========
Options -Indexes

# ======== PROTEGER ARCHIVOS SENSIBLES ========
<FilesMatch "\.git">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "\.(env|config|json)$">
    Order allow,deny
    Deny from all
</FilesMatch>
